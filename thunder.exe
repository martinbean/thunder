void match_intro(u_long *addr,int param_2)

{
  int *selected_wrestler;
  uint uVar1;
  int i;
  uint uVar2;
  short sVar3;
  int number_of_players;
  RECT rect;
  GsIMAGE tim;
  bool movie_unavailable;
  
  switch(game_mode) {
  default:
    number_of_players = 2;
    break;
  case 1P_Exhibition_Tag_Team:
  case 2P_VS_Tag_Team:
  case 1P_Battle_Royal:
  case 2P_VS_Battle_Royal:
  case DEMO_Tag_Team:
    number_of_players = 4;
  }
  movie_unavailable = false;
  i = 0;
  if (number_of_players != 0) {
    selected_wrestler = selected_wrestlers;
    do {
                    // Only the first 64 wrestlers have an intro movie
      if (0x3f < *selected_wrestler) {
        movie_unavailable = true;
      }
      i = i + 1;
      selected_wrestler = selected_wrestler + 1;
    } while (i < number_of_players);
  }
                    // At least one selected wrestler does not have an intro movie
                    // Show "Tonight's Special Event" graphic instead
  if (movie_unavailable) {
