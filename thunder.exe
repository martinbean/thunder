void pick_random_ring(void)

{
  int seed;
  Ring index;
  
  if (ring == Random) {
    do {
      do {
        seed = rand();
        index = seed % 0x1d;
      } while (unlocked_rings[index] == false);
    } while (index == Turbo);
  }
  else {
    game_ring = ring;
    index = game_ring;
  }
  game_ring = index;
  is_turbo_ring = game_ring == Turbo;
  return;
}



